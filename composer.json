{
    "name": "integrator/owner-analytics",
    "type": "project",
    "description": "Owner analytics dashboard for an amoCRM integrator studio.",
    "keywords": [
        "laravel",
        "analytics",
        "dashboard",
        "amoCRM"
    ],
    "license": "proprietary",
    "require": {
        "php": "^8.3",
        "fakerphp/faker": "^1.24",
        "filament/filament": "^5.0",
        "guzzlehttp/guzzle": "^7.8",
        "laravel/framework": "^12.0",
        "laravel/tinker": "^2.9",
        "livewire/livewire": "^4.0",
        "phpoffice/phpspreadsheet": "^1.30",
        "psr/simple-cache": "^2.0",
        "pxlrbt/filament-excel": "^3.0",
        "ufee/amoapi-v4": "^1.1",
        "weeek/weeek-client-php": "^1.0"
    },
    "require-dev": {
        "laravel/pint": "^1.18",
        "nunomaduro/collision": "^8.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "@php artisan package:discover --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ],
        "lint": [
            "vendor/bin/pint"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "platform": {
            "php": "8.4.0"
        },
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
